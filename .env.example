# bestdishintown — environment variables
# Copy this to .env.local for development
# Add all of these to Vercel dashboard under Project > Settings > Environment Variables

# ── Google Places API ──────────────────────────────────────────
# Get from: https://console.cloud.google.com
# Enable: Places API (New)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── Outscraper (Google Reviews) ────────────────────────────────
# Get from: https://app.outscraper.com/api-docs
# Plan: Pay-per-use — ~$1–3 per 100 reviews
OUTSCRAPER_API_KEY=your_outscraper_api_key_here

# ── Anthropic (Claude Sonnet) ──────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Upstash Redis (Caching) ────────────────────────────────────
# Get from: https://console.upstash.com
# Free tier: 10k requests/day — plenty for MVP
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
